# 统一环境文件：
# - `./start.sh` 读取它启动本地模式（仅绑定 127.0.0.1）
# - `./start-nginx.sh` 读取它启动公网模式（nginx + 生产后端）
# - 首次执行 `start-nginx.sh` 时，如果根目录 `.env` 不存在，会尝试合并旧的
#   `backend/.env`、`backend/.env.production`、`frontend/.env`

# 后端本机监听
PORT=5001
BIND_HOST=127.0.0.1

# 前端本地开发端口
FRONTEND_PORT=3001

# 公网入口
# 建议显式填写；若留空，`start-nginx.sh` 会自动探测并提示确认
PUBLIC_HOST=
PUBLIC_PORT=8088
PUBLIC_SCHEME=http

# 兼容旧逻辑保留。通常不需要手改，脚本会自动维护。
PUBLIC_ORIGIN=
FRONTEND_ORIGIN=
CORS_ORIGINS=
SOCKET_CORS_ORIGINS=
NGINX_SCHEME=http
# NGINX_SSL_CERT_PATH=/etc/letsencrypt/live/example/fullchain.pem
# NGINX_SSL_KEY_PATH=/etc/letsencrypt/live/example/privkey.pem

# 数据库与后端核心配置
MONGODB_URI=mongodb://localhost:27017/strategy-game
CHAT_DB_MODE=split
CHAT_DB_NAME=strategy-game-chat
CHAT_MONGODB_URI=mongodb://localhost:27017/strategy-game-chat
JWT_SECRET=replace-with-a-strong-secret

NOTIFICATION_COLLECTION_READ=true
NOTIFICATION_DUAL_WRITE=true
